# ACRCloud API credentials
# Sign up at https://www.acrcloud.com/ to get these values
ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com
ACRCLOUD_ACCESS_KEY=your_access_key_here
ACRCLOUD_ACCESS_SECRET=your_access_secret_here

# Optional: override the ACRCloud endpoint path (default: /v1/identify)
ACRCLOUD_ENDPOINT=/v1/identify

# Max file size in bytes for each chunk (default: 4MB to stay under Vercel's 4.5MB limit)
MAX_CHUNK_SIZE=4194304

# Port for local development server
PORT=3000
